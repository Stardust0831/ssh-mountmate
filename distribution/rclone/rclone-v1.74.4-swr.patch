+	initial, err := root.ReadDirAll()
+	require.NoError(t, err)
+	assert.Equal(t, []string{"old.txt"}, nodeNames(initial))
+
+	r.WriteObject(context.Background(), "new.txt", "new", t2)
+	f.block.Store(true)
+	done := make(chan error, 1)
